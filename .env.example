# === Webtop Chromium CDP 配置（轻量版，适合 2GB 服务器）===

# Web 桌面用户名（为空则无认证）
WEBTOP_USER=aria
# Web 桌面密码（为空则无认证）
WEBTOP_PASSWORD=veta@2Link

# CDP 认证 Token（为空则不认证）
WEBTOP_CDP_TOKEN=kane-cdp-1

# CDP 外部映射端口
WEBTOP_CDP_PORT=9227

# --- Selkies 桌面画质 & 性能 ---

# 最大帧率（范围 8-120，或固定值如 "30"）
SELKIES_FRAMERATE=24

# 编码器（可选: x264enc, x264enc-striped, jpeg）
SELKIES_ENCODER=jpeg

# JPEG 画质（范围 1-100，值越大越清晰，带宽占用越高）
SELKIES_JPEG_QUALITY=80

# --- 音频 ---

# 启用音频（默认开启）
SELKIES_AUDIO_ENABLED=true

# 启用麦克风
SELKIES_MICROPHONE_ENABLED=false

# 音频码率 (bps)
SELKIES_AUDIO_BITRATE=320000

# --- 分辨率 ---

# 手动指定分辨率（设置后锁定分辨率，不受客户端窗口影响）
SELKIES_MANUAL_WIDTH=1280
SELKIES_MANUAL_HEIGHT=720
