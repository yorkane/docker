# === Webtop Chromium CDP 配置（轻量版，适合 2GB 服务器）===

# Web 桌面用户名（为空则无认证）
WEBTOP_USER=aria
# Web 桌面密码（为空则无认证）
WEBTOP_PASSWORD=veta@2Link

# CDP 认证 Token（嵌入 URL 路径，如 https://host:9227/<token>/json/version）
# 为空则无需 Token，直接 https://host:9227/json/version
WEBTOP_CDP_TOKEN=kane-cdp-1

# --- 端口配置 ---

# 暴露在外的 Web 桌面端口 (浏览器访问 Web UI 的端口)
WEBTOP_PORT=3001

# Web 桌面容器内部映射端口 (3001 为 HTTPS 加密，3000 为纯 HTTP)
# 如果您使用了 Nginx 反向代理或需要纯 HTTP，请改为 3000
WEBTOP_CONTAINER_PORT=3001

# CDP 外部映射端口
WEBTOP_CDP_PORT=9227

# 是否禁用 CDP 代理的 HTTPS 加密（设为 true 则使用纯 HTTP/WS 暴露 CDP 控制端）
# 默认 false (开启 TLS 加密)
# WEBTOP_CDP_DISABLE_HTTPS=true

# --- TLS 证书（可选，不设置则自动生成自签名证书）---

# WEBTOP_CDP_TLS_CERT=/config/ssl/cdp-cert.pem
# WEBTOP_CDP_TLS_KEY=/config/ssl/cdp-key.pem

# --- Selkies 桌面画质 & 性能 ---

# 最大帧率（范围 8-120，或固定值如 "30"）
SELKIES_FRAMERATE=24

# 编码器（可选: x264enc, x264enc-striped, jpeg）
SELKIES_ENCODER=jpeg

# JPEG 画质（范围 1-100，值越大越清晰，带宽占用越高）
SELKIES_JPEG_QUALITY=80

# --- 音频 ---

# 启用音频（默认开启）
SELKIES_AUDIO_ENABLED=true

# 启用麦克风
SELKIES_MICROPHONE_ENABLED=false

# 音频码率 (bps)
SELKIES_AUDIO_BITRATE=320000

# --- 分辨率 ---

# 手动指定分辨率（设置后锁定分辨率，不受客户端窗口影响）
SELKIES_MANUAL_WIDTH=1280
SELKIES_MANUAL_HEIGHT=720

# --- 浏览器 ---

# 是否启用软件 GPU 加速 (针对无硬件 GPU 服务器，解决 WebGL 崩溃问题)
# CHROME_ENABLE_GPU=true

# 浏览器界面语言 (默认 zh-CN)
# CHROME_LANGUAGE=en-US
