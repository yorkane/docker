# === Kasm Chrome CDP 配置 ===

# KasmVNC Web 桌面密码（设为 'disabled' 禁用认证，设为具体密码启用认证）
KASM_VNC_PW=disabled

# CDP 认证 Token（为空则不启用认证，所有请求直接放行）
KASM_CDP_TOKEN=

# CDP 外部映射端口
KASM_CDP_PORT=9226

# VNC 分辨率
KASM_RESOLUTION=1280x768

# VNC 最大帧率
KASM_MAX_FRAME_RATE=8

# JPEG 压缩质量 (0-9，9 最高)
KASM_JPEG_QUALITY=7

# 最大编码质量 (0-9)
KASM_MAX_QUALITY=8
