#!/usr/bin/with-contenv bash
# s6 服务：Chromium 浏览器（自动重启）
# 以 abc 用户身份运行 chrome-wrapper.sh

# 确保数据目录存在并归属 PUID 用户（默认 1000）
mkdir -p /config/chromium-data
chown -R "${PUID:-1000}:${PGID:-1000}" /config/chromium-data
# 清理可能残留的 SingletonLock
rm -f /config/chromium-data/SingletonLock

# 等待 X server 就绪
echo "⏳ 等待桌面环境就绪..."
until xdpyinfo -display "${DISPLAY:-:1}" >/dev/null 2>&1; do
    sleep 1
done
echo "✅ 桌面环境就绪 (DISPLAY=${DISPLAY:-:1})"

# 启动 D-Bus 会话总线（扩展需要）
if command -v dbus-launch >/dev/null 2>&1; then
    eval $(dbus-launch --sh-syntax)
    export DBUS_SESSION_BUS_ADDRESS
    echo "✅ D-Bus 会话总线已启动: $DBUS_SESSION_BUS_ADDRESS"
fi

# 确保扩展目录和下载目录存在
mkdir -p /config/extensions /config/downloads
chown -R "${PUID:-1000}:${PGID:-1000}" /config/extensions /config/downloads

# 设置 Chromium 默认下载目录为 /config/downloads
PREFS_DIR="/config/chromium-data/Default"
PREFS_FILE="${PREFS_DIR}/Preferences"
mkdir -p "$PREFS_DIR"
if [ ! -f "$PREFS_FILE" ]; then
    # 首次启动：创建 Preferences 并设置下载目录
    cat > "$PREFS_FILE" <<'EOF'
{
  "download": {
    "default_directory": "/config/downloads",
    "prompt_for_download": false
  }
}
EOF
    chown "${PUID:-1000}:${PGID:-1000}" "$PREFS_FILE"
    echo "✅ 已设置默认下载目录: /config/downloads"
elif ! grep -q '"/config/downloads"' "$PREFS_FILE" 2>/dev/null; then
    # 已有 Preferences 但未设置下载目录：用 python/sed 注入
    if command -v python3 >/dev/null 2>&1; then
        python3 -c "
import json, sys
with open('$PREFS_FILE', 'r') as f:
    prefs = json.load(f)
prefs.setdefault('download', {})['default_directory'] = '/config/downloads'
with open('$PREFS_FILE', 'w') as f:
    json.dump(prefs, f, indent=2)
" 2>/dev/null && echo "✅ 已更新下载目录: /config/downloads"
    fi
fi

# 启动 Chromium（exec 让 s6 管理进程生命周期）
exec s6-setuidgid abc /usr/local/bin/chrome-wrapper.sh
